# Purpose: Zero-Host execution environment for PKD validation.
# ========================================================================

FROM public.ecr.aws/docker/library/rust:latest AS rust-builder

# Install build dependencies
RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js v24 (LTS) for workspace management
RUN curl -fsSL https://deb.nodesource.com/setup_24.x | bash - \
    && apt-get install -y nodejs \
    && npm install -g npm@latest

# Install cargo-audit for Rust vulnerability scanning
RUN cargo install cargo-audit

WORKDIR /work
COPY . .

# Ensure workspaces are recognized even if empty
RUN mkdir -p apps packages

# Default command: Audit then Test
CMD ["sh", "-c", "npm run audit && npm test"]
