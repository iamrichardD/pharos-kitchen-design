 * License: FSL-1.1 (See LICENSE file for details)
 * Purpose: Device Authorization Handshake (RFC 8628) Verification Page.
 * Traceability: ADR 0018, ADR 0021, Issue #7
 * ======================================================================== */

import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Device Verification | Pharos Identity Bridge">
  <main class="max-w-4xl mx-auto px-6 py-20 min-h-screen flex flex-col items-center justify-center blueprint-grid transition-colors duration-300">
    <div class="w-full max-w-md bg-bg-base/40 border border-border-blueprint/20 p-10 relative overflow-hidden blueprint-border">
      
      <!-- Grid Decoration -->
      <div class="absolute inset-0 opacity-5 pointer-events-none blueprint-grid"></div>

      <div class="relative z-10 text-center">
        <h1 class="text-4xl font-bold mb-4 font-mono tracking-tighter italic uppercase text-text-base">
          VERIFY_DEVICE
        </h1>
        <p class="text-text-muted mb-10 text-sm leading-relaxed font-mono">
          Enter the code displayed on your device and authenticate to link your identity.
        </p>

        <form id="verify-form" class="space-y-6">
          <div class="space-y-2 text-left">
            <label for="user_code" class="block text-[10px] font-mono text-ph-blue uppercase tracking-widest">
              [USER_CODE]
            </label>
            <input 
              type="text" 
              id="user_code" 
              name="user_code" 
              placeholder="ABCD-1234"
              class="w-full bg-bg-base/60 border border-border-blueprint/40 px-4 py-4 text-center text-3xl font-mono text-ph-orange placeholder:text-text-muted focus:outline-none focus:border-ph-orange transition-colors"
              maxlength="9"
              required
            />
          </div>

          <!-- Added Email/Password fields for direct SRP login -->
          <div class="space-y-4 text-left">
            <div class="space-y-2">
                <label for="email" class="block text-[10px] font-mono text-ph-blue uppercase tracking-widest">[IDENTITY_EMAIL]</label>
                <input type="email" id="email" name="email" required class="w-full bg-bg-base/60 border border-border-blueprint/20 px-3 py-2 font-mono text-text-base text-sm focus:outline-none focus:border-ph-orange" />
            </div>
            <div class="space-y-2">
                <label for="password" class="block text-[10px] font-mono text-ph-blue uppercase tracking-widest">[IDENTITY_SECRET]</label>
                <input type="password" id="password" name="password" required class="w-full bg-bg-base/60 border border-border-blueprint/20 px-3 py-2 font-mono text-text-base text-sm focus:outline-none focus:border-ph-orange" />
            </div>
          </div>

          <div id="status-container" class="hidden text-xs font-mono py-2 px-4 border-l-2 border-ph-orange bg-ph-orange/10 text-ph-orange text-left mb-6">
            <!-- Dynamic Status -->
          </div>

          <button 
            type="submit" 
            id="submit-btn"
            class="w-full bg-ph-blue text-ph-charcoal font-bold py-4 hover:bg-white transition-colors uppercase tracking-widest text-sm"
          >
            Authorize Device
          </button>
        </form>

        <div id="success-container" class="hidden space-y-6">
            <div class="text-emerald-500 text-6xl mb-4">✓</div>
            <h2 class="text-2xl font-bold text-text-base uppercase tracking-tighter">Device Authorized</h2>
            <p class="text-text-muted text-sm leading-relaxed font-mono">
              The cryptographic handshake is complete. You can now return to your device.
            </p>
            <a href="/pharos-kitchen-design/roadmap" class="inline-block mt-8 text-ph-blue hover:text-white transition-colors font-mono text-xs uppercase tracking-widest">
                Return to Matrix >>
            </a>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  import { Amplify } from 'aws-amplify';
  import { signIn, fetchAuthSession } from 'aws-amplify/auth';

  // Configure Amplify from env variables (Astro handles these)
  Amplify.configure({
    Auth: {
      Cognito: {
        userPoolId: import.meta.env.PUBLIC_COGNITO_USER_POOL_ID,
        userPoolClientId: import.meta.env.PUBLIC_COGNITO_CLIENT_ID,
      }
    }
  });
  
  const form = document.getElementById('verify-form') as HTMLFormElement;
  const statusContainer = document.getElementById('status-container');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const successContainer = document.getElementById('success-container');

  const showStatus = (msg: string, isError = false) => {
    if (!statusContainer) return;
    statusContainer.innerText = `>> ${msg}`;
    statusContainer.classList.remove('hidden');
    statusContainer.style.borderColor = isError ? '#ef4444' : '#f97316';
    statusContainer.style.color = isError ? '#ef4444' : '#f97316';
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const user_code = formData.get('user_code') as string;
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;

    submitBtn.disabled = true;
    submitBtn.innerText = "AUTHORIZING...";
    showStatus("Initiating Cognito SRP Handshake...");

    try {
        // 1. Authenticate with Cognito
        const { isSignedIn, nextStep } = await signIn({ username: email, password });
        
        if (!isSignedIn) {
            throw new Error(`Authentication incomplete: ${nextStep.signInStep}`);
        }

        showStatus("Persona Verified. Retrieving Cryptographic Proof...");
        
        // 2. Get the current session tokens
        const session = await fetchAuthSession();
        const idToken = session.tokens?.idToken?.toString();
        const accessToken = session.tokens?.accessToken?.toString();
        const refreshToken = session.tokens?.accessToken?.toString(); // Cognito Refresh is handled differently but we pass it for the bridge
        const sub = session.userSub;

        showStatus("Linking Edge Bridge...");
        
        // 3. Call the Auth Bridge (Worker) to approve the device code
        const response = await fetch('https://auth.iamrichardd.com/auth/confirm', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                user_code: user_code.replace('-', '').toUpperCase(),
                sub,
                access_token: accessToken,
                id_token: idToken,
                refresh_token: refreshToken
            })
        });

        if (!response.ok) {
            const err = await response.json() as any;
            throw new Error(err.error || "Bridge handshake failed");
        }

        form.classList.add('hidden');
        successContainer?.classList.remove('hidden');

    } catch (err: any) {
        showStatus(err.message, true);
        submitBtn.disabled = false;
        submitBtn.innerText = "Authorize Device";
    }
  });

  // Auto-format user_code (ABCD-1234)
  const input = document.getElementById('user_code') as HTMLInputElement;
  input?.addEventListener('input', () => {
    let value = input.value.replace(/[^a-zA-Z0-9]/g, '').toUpperCase();
    if (value.length > 4) {
      value = value.slice(0, 4) + '-' + value.slice(4, 8);
    }
    input.value = value;
  });
</script>

<style>
  /* Local overrides removed in favor of global blueprint utilities */
</style>
