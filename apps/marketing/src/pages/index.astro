---
/**
 * Project: Pharos Kitchen Design (Project Prism)
 * Component: Pages / Home
 * File: index.astro
 * Author: Richard D. (https://github.com/iamrichardd)
 * Purpose: The IKD Manifesto and primary landing page.
 * Traceability: ADR 0012, ADR 0015
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import BlueprintCard from '../components/BlueprintCard.astro';
---

<BaseLayout title="The IKD Manifesto">
	<section class="py-20 bg-ph-charcoal/40">
		<div class="container mx-auto px-4 text-center">
			<h1 class="text-5xl md:text-7xl mb-6">BIM without the <span class="text-ph-orange">Bloat.</span></h1>
			<p class="text-xl md:text-2xl text-gray-400 max-w-3xl mx-auto mb-10 leading-relaxed font-sans">
				Replace 15MB legacy RFAs with &lt;1MB metadata-first models. 
				Deterministic data, verified by manufacturers, delivered to your design board.
			</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<a href="/pharos-kitchen-design/features" class="bg-ph-orange text-ph-charcoal font-condensed font-bold text-xl px-10 py-4 hover:bg-white transition-colors">EXPLORE CAPABILITIES</a>
				<a href="https://github.com/iamrichardD/pharos" class="border border-ph-blue text-ph-blue font-condensed font-bold text-xl px-10 py-4 hover:bg-ph-blue hover:text-white transition-colors">VIEW SOURCE</a>
			</div>
		</div>
	</section>

	<section class="py-16 container mx-auto px-4">
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
			<BlueprintCard title="LIVE-SYNC TRUTH">
				<p class="text-gray-400 leading-relaxed text-sm">
					Legacy data is a snapshot of the past. Pharos verifies every URL and dimension against manufacturer portals on a 30-day "Pulse" cycle.
				</p>
			</BlueprintCard>
			
			<BlueprintCard title="METADATA-FIRST">
				<p class="text-gray-400 leading-relaxed text-sm">
					We don't just convert files; we normalize the logic. Pharos provides a unified schema that survives exports and software migrations.
				</p>
			</BlueprintCard>

			<BlueprintCard title="COMMAND-FIRST UX">
				<p class="text-gray-400 leading-relaxed text-sm">
					Stop folder-diving. Cmd+K to search, filter, and place equipment in milliseconds. Designed for the high-velocity designer.
				</p>
			</BlueprintCard>

			<BlueprintCard title="VERIFIED IDENTITY">
				<p class="text-gray-400 leading-relaxed text-sm">
					Trust but verify. Our Hero Protocol uses cryptographically signed metadata to ensure that what you specify is manufacturer-authorized.
				</p>
			</BlueprintCard>
		</div>
	</section>

	<section class="py-20 bg-ph-blue/5 border-y border-ph-blue/10">
		<div class="container mx-auto px-4 flex flex-col md:flex-row items-center gap-12">
			<div class="flex-1">
				<h2 class="text-4xl mb-6">Eliminating the <span class="text-ph-blue">Hallucination Gap.</span></h2>
				<p class="text-gray-300 text-lg mb-8 leading-relaxed">
					The biggest cost in kitchen design is "Toil"—manual verification of stale data. 
					Pharos provides the **Direct-to-Manufacturer Link**, ensuring that what you specify is exactly what ships.
				</p>
				<ul class="space-y-4 font-mono text-sm uppercase text-ph-blue">
					<li class="flex gap-3"><span class="text-ph-orange">>></span> Automated URL Verification (3M, Vulcan, etc.)</li>
					<li class="flex gap-3"><span class="text-ph-orange">>></span> GUID Parity across BIM/CAD Environments</li>
					<li class="flex gap-3"><span class="text-ph-orange">>></span> Open Schema (FSL-1.1) for Community Trust</li>
				</ul>
			</div>
			<div class="flex-1 w-full">
				<div class="blueprint-border p-2 bg-black/40 aspect-video flex items-center justify-center font-mono text-xs text-ph-blue/50">
					<img src="/pharos-kitchen-design/assets/screenshots/hero-interaction.png" alt="Prototype Interaction" class="w-full h-full object-cover opacity-80" />
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
