---
/**
 * Project: Pharos Kitchen Design (Project Prism)
 * Component: Pages / Home
 * File: index.astro
 * Author: Richard D. (https://github.com/iamrichardd)
 * Purpose: The IKD Manifesto and primary landing page.
 * Traceability: ADR 0012, ADR 0015
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import BlueprintCard from '../components/BlueprintCard.astro';
---

<BaseLayout title="Professional Kitchen Design | The IKD Manifesto">
	<section class="py-20 bg-bg-base/40 transition-colors duration-300">
		<div class="container mx-auto px-4 text-center">
			<h1 class="text-5xl md:text-7xl mb-6">Design at the <span class="text-ph-orange">Speed of Thought.</span></h1>
			<p class="text-xl md:text-2xl text-text-muted max-w-3xl mx-auto mb-10 leading-relaxed font-sans">
				Spend more time designing and less time hunting for spec sheets. 
				Pharos delivers manufacturer-verified equipment data directly to your board.
			</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<a href="/pharos-kitchen-design/features" class="bg-ph-orange text-ph-charcoal font-condensed font-bold text-xl px-10 py-4 hover:bg-ph-blue hover:text-white transition-colors">EXPLORE CAPABILITIES</a>
				<a href="https://github.com/iamrichardD/pharos" class="border border-ph-blue text-ph-blue font-condensed font-bold text-xl px-10 py-4 hover:bg-ph-blue hover:text-white transition-colors">VIEW PROJECT</a>
			</div>
		</div>
	</section>

	<section class="py-16 container mx-auto px-4">
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
			<BlueprintCard title="AUTOMATED ACCURACY">
				<p class="text-text-muted leading-relaxed text-sm">
					Manual verification is a thing of the past. Pharos double-checks every model number and dimension against official manufacturer portals every 30 days.
				</p>
			</BlueprintCard>
			
			<BlueprintCard title="UNIVERSAL DNA">
				<p class="text-text-muted leading-relaxed text-sm">
					Your specifications stay connected. Pharos provides a smart data layer that survives exports and software transitions without losing its "Truth."
				</p>
			</BlueprintCard>

			<BlueprintCard title="INSTANT DISCOVERY">
				<p class="text-text-muted leading-relaxed text-sm">
					Stop folder-diving. Find, filter, and place professional equipment in milliseconds. Designed for the high-velocity independent designer.
				</p>
			</BlueprintCard>

			<BlueprintCard title="DESIGNER PASSPORT">
				<p class="text-text-muted leading-relaxed text-sm">
					Work securely from any device. Your saved preferences and manufacturer permissions follow you from the office to the job site.
				</p>
			</BlueprintCard>
		</div>
	</section>

	<section class="py-20 bg-ph-blue/5 border-y border-border-blueprint transition-colors duration-300">
		<div class="container mx-auto px-4 flex flex-col md:flex-row items-center gap-12">
			<div class="flex-1">
				<h2 class="text-4xl mb-6">Built for <span class="text-ph-blue">Professional Confidence.</span></h2>
				<p class="text-text-base/80 text-lg mb-8 leading-relaxed">
					The biggest cost in kitchen design is manual rework. 
					Pharos provides a **Direct-to-Manufacturer Link**, ensuring that what you specify is exactly what the factory ships.
				</p>
				<ul class="space-y-4 font-mono text-sm uppercase text-ph-blue">
					<li class="flex gap-3"><span class="text-ph-orange">>></span> Automated Spec Verification (Hobart, Vulcan, etc.)</li>
					<li class="flex gap-3"><span class="text-ph-orange">>></span> Seamless Data Transitions Between Tools</li>
					<li class="flex gap-3"><span class="text-ph-orange">>></span> Professional Sovereignty (You Own Your Data)</li>
				</ul>
			</div>
			<div class="flex-1 w-full">
				<div class="blueprint-border p-2 bg-bg-base/40 aspect-video flex items-center justify-center font-mono text-xs text-ph-blue/50">
					<picture class="w-full h-full">
						<source srcset="/pharos-kitchen-design/assets/screenshots/hero-interaction-light.png" media="(prefers-color-scheme: light)">
						<img src="/pharos-kitchen-design/assets/screenshots/hero-interaction-dark.png" alt="Pharos Interaction" class="w-full h-full object-cover opacity-80" />
					</picture>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
