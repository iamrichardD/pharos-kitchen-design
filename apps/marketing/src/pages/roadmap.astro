---
/* ========================================================================
 * Project: Pharos Kitchen Design (Project Prism)
 * Component: Marketing / Roadmap
 * File: src/pages/roadmap.astro
 * Author: Richard D. (https://github.com/iamrichardd)
 * License: FSL-1.1 (See LICENSE file for details)
 * Purpose: High-fidelity chronological "Technical Maturity Matrix" for PKD.
 * Traceability: ADR 0012, ADR 0021, Issue #20
 * ======================================================================== */

import BaseLayout from "../layouts/BaseLayout.astro";

const roadmapItems = [
  { 
    name: "Cognito PII Silo", 
    status: "Deployed", 
    phase: "Sprint 1", 
    tag: "CORE",
    description: "Hardened AWS Cognito User Pool with Opaque UUIDs for privacy-first attribution." 
  },
  { 
    name: "RFC 8628 Edge Bridge", 
    status: "Deployed", 
    phase: "Sprint 2", 
    tag: "IDENTITY",
    description: "Cross-platform identity handshake via Cloudflare Workers for sub-50ms polling." 
  },
  { 
    name: "WASM Bridge Core", 
    status: "Deployed", 
    phase: "Sprint 2", 
    tag: "BRIDGE",
    description: "Rust-to-WASM interop layer for cross-OS performance and metadata normalization." 
  },
  { 
    name: "Admin Control Plane", 
    status: "Deployed", 
    phase: "Sprint 3", 
    tag: "CORE",
    description: "Cognito orchestration and role-based access control for OEM/VDC administrators." 
  },
  { 
    name: "Shared Protocol (ADR 0024)", 
    status: "Deployed", 
    phase: "Sprint 3", 
    tag: "PROTOCOL",
    description: "High-rigor RFC 2378 Rust implementation unified across the Pharos ecosystem." 
  },
  { 
    name: "Hero Protocol (ABAC)", 
    status: "Blueprint Approved", 
    phase: "Sprint 3", 
    tag: "IDENTITY",
    description: "Manufacturer-specific claim sets for metadata signing and verification." 
  },
  { 
    name: "Ghost-Link Metadata", 
    status: "Research Phase", 
    phase: "Sprint 4", 
    tag: "BRIDGE",
    description: "Non-bloat Revit attribution via ephemeral metadata injection and GUID parity." 
  },
  { 
    name: "Spotlight Search (Cmd+K)", 
    status: "Blueprint Approved", 
    phase: "Sprint 5", 
    tag: "UX",
    description: "Lightning-fast equipment discovery and placement within the Revit environment." 
  },
  { 
    name: "WebMCP Server Interface", 
    status: "Blueprint Approved", 
    phase: "Sprint 6", 
    tag: "AI",
    description: "Standardized Model Context Protocol server for AI agent equipment queries." 
  },
  { 
    name: "Smart Specification", 
    status: "Research Phase", 
    phase: "Sprint 7", 
    tag: "AI",
    description: "Agent-driven equipment selection based on LEED, LOD, and manufacturer criteria." 
  }
];

// Deterministic Sort by Phase (Sprint 1 -> 2 -> 3...)
const sortedRoadmap = roadmapItems.sort((a, b) => a.phase.localeCompare(b.phase));
---

<BaseLayout title="Technical Maturity Matrix | Pharos Kitchen Design">
  <main class="max-w-6xl mx-auto px-6 py-20 min-h-screen">
    <div class="mb-20 border-l-4 border-ph-blue pl-8 py-4 bg-ph-blue/5 backdrop-blur-sm">
      <h1 class="text-6xl font-bold text-white tracking-tighter mb-4 font-mono italic uppercase">
        SYSTEM_VELOCITY_v1.1
      </h1>
      <p class="text-xl text-gray-400 max-w-3xl leading-relaxed">
        Pharos is a **Metadata-First Standard**. 
        Our roadmap tracks the chronological maturity of the system, prioritizing high-rigor foundations over features.
      </p>
    </div>

    <!-- Chronological Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {sortedRoadmap.map((item) => (
        <div class="group relative bg-ph-charcoal/40 border border-ph-blue/20 p-8 hover:border-ph-orange transition-all duration-300 shadow-lg hover:shadow-ph-orange/10 flex flex-col justify-between">
          
          <!-- Category Tag (Corner) -->
          <div class="absolute top-0 left-0 bg-ph-charcoal border-r border-b border-ph-blue/20 px-3 py-1 text-[9px] font-mono text-ph-blue uppercase tracking-widest">
            [{item.tag}]
          </div>

          <!-- Status Badge (Top Right) -->
          <div class={`absolute top-0 right-0 px-3 py-1 text-[10px] font-bold uppercase tracking-tighter text-ph-charcoal ${
            item.status === 'Deployed' ? 'bg-emerald-500' : 
            item.status === 'In Construction' ? 'bg-ph-blue' :
            item.status === 'Blueprint Approved' ? 'bg-amber-500' : 'bg-gray-500'
          }`}>
            {item.status}
          </div>

          <div class="mt-4">
            <div class="text-xs font-mono text-ph-orange mb-2 uppercase tracking-widest font-bold">{item.phase}</div>
            <h3 class="text-2xl font-bold text-white mb-4 tracking-tight">{item.name}</h3>
            <p class="text-gray-400 text-sm leading-relaxed mb-6 italic">
              {item.description}
            </p>
          </div>

          <!-- Blueprint Line Decoration -->
          <div class="mt-4 pt-4 border-t border-white/5 flex justify-between items-center opacity-40 group-hover:opacity-100 transition-opacity">
            <div class="text-[9px] font-mono text-gray-600 uppercase">SPEC_ID: {item.name.replace(/\s+/g, '_').toUpperCase()}</div>
            <div class="h-px flex-1 mx-4 bg-white/10"></div>
            <div class="w-2 h-2 border border-ph-blue/40 rounded-full"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Final CTA -->
    <div class="mt-32 p-12 bg-black/40 border-b-8 border-ph-blue relative overflow-hidden blueprint-border">
      <div class="relative z-10">
        <h2 class="text-3xl font-bold mb-6 font-mono tracking-tighter text-white">CONTRIBUTE_TO_THE_BLUEPRINT</h2>
        <p class="text-gray-400 max-w-2xl mb-8 leading-relaxed">
          Pharos is built for the IKD community. Our roadmap is an open specification for the future of AEC data sovereignty.
        </p>
        <a href="https://github.com/iamrichardD/pharos-kitchen-design" class="inline-block px-10 py-4 bg-ph-blue text-ph-charcoal font-bold transition-colors uppercase tracking-widest text-sm hover:bg-white">
          Join the Development
        </a>
      </div>
      <!-- Grid Background Decoration -->
      <div class="absolute inset-0 opacity-5 pointer-events-none" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 20px 20px;"></div>
    </div>
  </main>
</BaseLayout>

<style>
  /* High-rigor Blueprint texture */
  main {
    background-image: radial-gradient(circle at 1.5px 1.5px, #1e293b 1.5px, transparent 0);
    background-size: 60px 60px;
  }
  .blueprint-border {
    border: 1px solid rgba(59, 130, 246, 0.2);
  }
</style>
