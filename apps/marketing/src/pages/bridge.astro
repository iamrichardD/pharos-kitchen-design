---
/* ========================================================================
 * Project: Pharos Kitchen Design (Project Prism)
 * Component: Pages / Bridge
 * File: bridge.astro
 * Author: Richard D. (https://github.com/iamrichardd)
 * Purpose: Technical overview of the Edge Identity Handshake & Ghost-Link.
 * Traceability: ADR 0015, ADR 0021
 * ======================================================================== */

import BaseLayout from "../layouts/BaseLayout.astro";
import BlueprintCard from "../components/BlueprintCard.astro";
---

<BaseLayout title="The Bridge | Designer Connectivity">
  <section class="py-20 bg-bg-base/60 relative overflow-hidden transition-colors duration-300">
    <div class="container mx-auto px-4 relative z-10">
      <h1 class="text-6xl font-bold mb-6 font-mono tracking-tighter italic">THE_BRIDGE</h1>
      <p class="text-xl text-text-muted max-w-2xl leading-relaxed">
        Pharos eliminates the gap between your web tools and your desktop design software. Our connectivity layer ensures your professional persona is available wherever you work—from the web portal to the Revit command line.
      </p>
    </div>
    <!-- Blueprint Grid Decoration -->
    <div class="absolute inset-0 blueprint-grid-lg opacity-20 pointer-events-none"></div>
  </section>

  <section class="py-20 container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
      <!-- 01 // ONE IDENTITY -->
      <div class="space-y-8">
        <div class="text-ph-orange font-mono text-sm tracking-widest uppercase">01 // DESIGNER IDENTITY</div>
        <h2 class="text-4xl font-bold">One Login, <span class="text-ph-blue">Any Platform.</span></h2>
        <p class="text-text-base/80 leading-relaxed text-lg">
          Stop managing separate passwords for every design tool. Pharos uses professional identity standards to synchronize your profile across your entire workflow.
        </p>
        <div class="bg-bg-base/40 border-l-4 border-ph-orange p-6 font-mono text-xs space-y-2">
          <div class="text-text-muted">>> Initializing Designer Handshake...</div>
          <div class="text-ph-blue">S: Identity Verified: ABCD-1234</div>
          <div class="text-text-muted">>> Connection established on all devices.</div>
        </div>
        <p class="text-text-muted text-sm italic">
          Optimized for global performance, ensuring you're always connected.
        </p>
      </div>

      <!-- 02 // CONNECTED SPECS -->
      <div class="space-y-8">
        <div class="text-ph-blue font-mono text-sm tracking-widest uppercase">02 // CONNECTED SPECIFICATIONS</div>
        <h2 class="text-4xl font-bold">Deterministic <span class="text-ph-orange">Accuracy.</span></h2>
        <p class="text-text-base/80 leading-relaxed text-lg">
          Your equipment details shouldn't vanish when you export a project. Pharos ensures that manufacturer attributes and GUIDs stay locked to your 3D models, surviving the transition between design and project management.
        </p>
        <div class="blueprint-border p-4 bg-bg-base/20 aspect-video flex items-center justify-center">
            <picture class="w-full h-full">
              <source srcset="/pharos-kitchen-design/assets/screenshots/ghost-link-metadata-light.png" media="(prefers-color-scheme: light)">
              <img src="/pharos-kitchen-design/assets/screenshots/ghost-link-metadata-dark.png" alt="Connected Specifications" class="w-full h-full object-cover opacity-60" />
            </picture>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 border-t border-border-blueprint/20">
    <div class="container mx-auto px-4 text-center">
        <h3 class="text-2xl mb-8 font-mono tracking-widest uppercase">Status: <span class="text-emerald-500">Global Connectivity Active</span></h3>
        <a href="/pharos-kitchen-design/roadmap" class="inline-block bg-ph-blue text-ph-charcoal font-bold px-10 py-4 hover:bg-white transition-colors uppercase tracking-widest text-sm">
            View Technical Maturity
        </a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Local overrides removed in favor of global blueprint-border and blueprint-grid classes */
</style>
