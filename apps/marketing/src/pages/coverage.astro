---
/**
 * Project: Pharos Kitchen Design (Project Prism)
 * Component: Pages / Coverage
 * File: coverage.astro
 * Author: Richard D. (https://github.com/iamrichardd)
 * Purpose: Visualizes equipment category coverage and sync vitality.
 * Traceability: ADR 0015
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import MaturityGrid from '../components/MaturityGrid.astro';
---

<BaseLayout title="Coverage & Sync Vitality">
	<section class="py-16 container mx-auto px-4 transition-colors duration-300">
		<div class="mb-12">
			<h1 class="text-4xl md:text-5xl mb-4">Maturity Matrix.</h1>
			<p class="text-text-muted max-w-2xl font-sans leading-relaxed">
				Tracking the evolution of our "Truth Engine." Every category is seed-mapped from legacy data and verified against manufacturer live portals on a 30-day "Pulse" cycle.
			</p>
		</div>

		<MaturityGrid />

		<div class="mt-20 blueprint-border p-8 bg-ph-orange/5 border-ph-orange/20">
			<div class="flex flex-col md:flex-row items-center gap-10">
				<div class="flex-1">
					<h2 class="text-ph-orange text-3xl mb-4 uppercase">WebMCP North Star</h2>
					<p class="text-text-base/80 mb-6 leading-relaxed">
						Pharos is built for humans and AI agents. Our WebMCP (Model Context Protocol) interface allows emergent behaviors—allowing AI assistants to directly query manufacturer metadata for intelligent selection.
					</p>
					<div class="flex gap-4 items-center">
						<span class="text-xs text-ph-orange font-bold uppercase tracking-widest border border-ph-orange/30 px-3 py-1">PHASE 4: AGENTIC INTEGRATION</span>
					</div>
				</div>
				<div class="w-full md:w-1/3 h-32 bg-bg-base/60 flex items-center justify-center font-mono text-[10px] text-text-muted uppercase border border-border-blueprint/20">
					[ VISUALIZING AGENTIC FLOW ]
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
